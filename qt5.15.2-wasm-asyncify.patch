diff --git a/src/plugins/platforms/wasm/qwasmeventdispatcher.cpp b/src/plugins/platforms/wasm/qwasmeventdispatcher.cpp
index 2e1b0835573..c1832625c48 100644
--- a/src/plugins/platforms/wasm/qwasmeventdispatcher.cpp
+++ b/src/plugins/platforms/wasm/qwasmeventdispatcher.cpp
@@ -100,8 +100,22 @@ bool QWasmEventDispatcher::processEvents(QEventLoop::ProcessEventsFlags flags)
     // app exit time. However, the browser expects that we return
     // control to it periodically, also after initial setup in main().
 
-    // EventLoopExec for nested event loops is not supported.
+#ifdef QT_HAVE_EMSCRIPTEN_ASYNCIFY
+    // With ASYNCIFY, emscripten_set_main_loop_arg() returns (instead of
+    // blocking forever), so QEventLoop::exec() will call processEvents()
+    // again. On re-entry (m_hasMainLoop already true), or for nested event
+    // loops (QDrag::exec, QMenu::exec, etc.), yield to the browser via
+    // emscripten_sleep so the outer main-loop callback keeps running, then
+    // process any pending Qt events before returning to the caller.
+    if (m_hasMainLoop) {
+        emscripten_sleep(0);
+        return QUnixEventDispatcherQPA::processEvents(flags & ~QEventLoop::EventLoopExec);
+    }
+#else
+    // Without ASYNCIFY, nested event loops are not supported.
     Q_ASSERT(!m_hasMainLoop);
+#endif
+
     m_hasMainLoop = true;
 
     // Call emscripten_set_main_loop_arg() with a callback which processes
